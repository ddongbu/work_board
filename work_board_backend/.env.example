# Application
PROJECT_NAME=Work Board
API_ENV=prod  # local | prod

# Database - DEV (로컬 직접 실행 시)
POSTGRES_SERVER_DEV=localhost
POSTGRES_PORT_DEV=5432
POSTGRES_USER_DEV=danny
POSTGRES_PASSWORD_DEV=
POSTGRES_DB_DEV=work_board

# Database - PROD (Docker 환경)
POSTGRES_SERVER_PROD=db
POSTGRES_PORT_PROD=5432
POSTGRES_USER_PROD=danny
POSTGRES_PASSWORD_PROD=
POSTGRES_DB_PROD=work_board

# CORS (콤마로 구분, 프론트 오리진 추가)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis - DEV
REDIS_HOST_DEV=localhost
REDIS_PORT_DEV=6379

# Redis - PROD
REDIS_HOST_PROD=redis
REDIS_PORT_PROD=6379
